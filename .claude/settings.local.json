{
  "permissions": {
    "allow": [
      "Bash(python -c ' *)",
      "Bash(pip show *)"
    ]
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo '🟢' > \"$TEMP/claude-status-light\"",
            "shell": "bash"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo '🔴' > \"$TEMP/claude-status-light\"",
            "shell": "bash"
          }
        ]
      }
    ]
  }
}
